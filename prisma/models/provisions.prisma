model Provision {
  id           String               @id @default(cuid())
  name         String
  amount       Float
  billingCycle BillingCycle
  nextRenewal  DateTime
  url          String?
  notes        String?
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  wayfarerId   String
  wayfarer     Wayfarer             @relation(fields: [wayfarerId], references: [id])
  markers      MarkersOnProvisions[]
}

model Expense {
  id         String             @id @default(cuid())
  name       String
  amount     Float
  date       DateTime
  notes      String?
  receiptUrl String?
  createdAt  DateTime           @default(now())
  wayfarerId String
  wayfarer   Wayfarer           @relation(fields: [wayfarerId], references: [id])
  markers    MarkersOnExpenses[]
}

model Budget {
  id         String   @id @default(cuid())
  markerId   String
  marker     Marker   @relation(fields: [markerId], references: [id])
  limit      Float
  month      Int
  year       Int
  wayfarerId String
  wayfarer   Wayfarer @relation(fields: [wayfarerId], references: [id])

  @@unique([wayfarerId, markerId, month, year])
}

enum BillingCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model MarkersOnProvisions {
  provision   Provision @relation(fields: [provisionId], references: [id], onDelete: Cascade)
  provisionId String
  marker      Marker    @relation(fields: [markerId], references: [id], onDelete: Cascade)
  markerId    String @map("tagId")

  @@id([provisionId, markerId])
  @@map("TagsOnProvisions")
}

model MarkersOnExpenses {
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId String
  marker    Marker  @relation(fields: [markerId], references: [id], onDelete: Cascade)
  markerId  String @map("tagId")

  @@id([expenseId, markerId])
  @@map("TagsOnExpenses")
}
