model AppearanceSettings {
  id                String          @id @default(cuid())
  sidebarDefault    SidebarDefault  @default(EXPANDED)
  defaultLandingPage String         @default("/basecamp")
  dateFormat        DateFormat      @default(MDY)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  wayfarerId        String          @unique
  wayfarer          Wayfarer        @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("appearance_settings")
}

enum SidebarDefault {
  EXPANDED
  COLLAPSED
}

enum DateFormat {
  MDY   // MM/DD/YYYY
  DMY   // DD/MM/YYYY
  YMD   // YYYY-MM-DD
}

model NotificationSettings {
  id                    String   @id @default(cuid())
  browserNotifications  Boolean  @default(false)
  notificationSound     Boolean  @default(true)
  emailDigest           DigestFrequency @default(NEVER)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  wayfarerId            String   @unique
  wayfarer              Wayfarer @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

enum DigestFrequency {
  NEVER
  DAILY
  WEEKLY
}

model PrivacySettings {
  id                  String            @id @default(cuid())
  manifestVisibility  ManifestVisibility @default(PUBLIC)
  contactFormEnabled  Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  wayfarerId          String            @unique
  wayfarer            Wayfarer          @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

enum ManifestVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model ItinerarySettings {
  id                  String        @id @default(cuid())
  defaultView         ItineraryView @default(MONTH)
  firstDayOfWeek      FirstDay      @default(SUNDAY)
  defaultEventDuration Int          @default(60)
  showWeekNumbers     Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  wayfarerId          String        @unique
  wayfarer            Wayfarer      @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("itinerary_settings")
}

enum ItineraryView {
  MONTH
  WEEK
  DAY
}

enum FirstDay {
  SUNDAY
  MONDAY
}

model WaypointSettings {
  id               String        @id @default(cuid())
  defaultSort      WaypointSort  @default(NEWEST)
  openInNewTab     Boolean       @default(true)
  waypointsPerPage Int           @default(25)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  wayfarerId       String        @unique
  wayfarer         Wayfarer      @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("waypoint_settings")
}

enum WaypointSort {
  NEWEST
  OLDEST
  TITLE_ASC
  TITLE_DESC
}
