model SignalSettings {
  id                  String     @id @default(cuid())
  messagesPerPage     Int        @default(25)
  autoMarkRead        Boolean    @default(true)
  autoRefreshInterval Int        @default(30)
  defaultView         SignalView @default(SIGNALS)
  compactView         Boolean    @default(false)
  showSnippets        Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  wayfarerId          String     @unique
  wayfarer            Wayfarer   @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("signal_settings")
}

enum SignalView {
  SIGNALS
  EMAIL
}
