model Log {
  id         String         @id @default(cuid())
  title      String?
  content    String
  position   Float?
  trailId    String?        @map("folderId")
  waypointId String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  wayfarerId String
  wayfarer   Wayfarer       @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)
  trail      Trail?         @relation(fields: [trailId], references: [id])
  waypoint   Waypoint?      @relation(fields: [waypointId], references: [id])
  markers    MarkersOnLogs[]

  @@map("logs")
}

model LogSettings {
  id           String   @id @default(cuid())
  logsPerPage  Int      @default(25)
  defaultSort  LogSort  @default(NEWEST)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  wayfarerId   String   @unique
  wayfarer     Wayfarer @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)

  @@map("log_settings")
}

enum LogSort {
  NEWEST
  OLDEST
}

model MarkersOnLogs {
  log      Log    @relation(fields: [logId], references: [id], onDelete: Cascade)
  logId    String
  marker   Marker @relation(fields: [markerId], references: [id], onDelete: Cascade)
  markerId String @map("tagId")

  @@id([logId, markerId])
  @@map("tags_on_logs")
}
