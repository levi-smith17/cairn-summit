model Marker {
  id         String              @id @default(cuid())
  name       String
  color      String
  icon       String?
  createdAt  DateTime            @default(now())
  wayfarerId String
  wayfarer   Wayfarer            @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)
  waypoints  MarkersOnWaypoints[]
  logs       MarkersOnLogs[]
  provisions MarkersOnProvisions[]
  expenses   MarkersOnExpenses[]
  stops      MarkersOnStops[]

  @@map("tags")
}
