model Tag {
  id         String            @id @default(cuid())
  name       String
  color      String
  icon       String?
  createdAt  DateTime          @default(now())
  wayfarerId String
  wayfarer   Wayfarer          @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)
  waypoints  TagsOnWaypoints[]
  logs       TagsOnLogs[]
  provisions TagsOnProvisions[]
  expenses   TagsOnExpenses[]

  @@map("tags")
}
