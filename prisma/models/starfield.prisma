model SfResourceType {
  id        String       @id @default(cuid())
  name      String       @unique
  plural    String
  resources SfResource[]

  @@map("sf_resource_types")
}

model SfResource {
  id           String          @id @default(cuid())
  name         String          @unique
  abbreviation String          @unique
  typeId       String
  type         SfResourceType  @relation(fields: [typeId], references: [id])

  // ManufacturedResource fields (null = raw resource)
  resource1Id  String?
  resource1    SfResource?     @relation("Recipe1", fields: [resource1Id], references: [id])
  resource2Id  String?
  resource2    SfResource?     @relation("Recipe2", fields: [resource2Id], references: [id])
  resource3Id  String?
  resource3    SfResource?     @relation("Recipe3", fields: [resource3Id], references: [id])
  resource4Id  String?
  resource4    SfResource?     @relation("Recipe4", fields: [resource4Id], references: [id])

  // Back relations
  usedAsRecipe1  SfResource[]  @relation("Recipe1")
  usedAsRecipe2  SfResource[]  @relation("Recipe2")
  usedAsRecipe3  SfResource[]  @relation("Recipe3")
  usedAsRecipe4  SfResource[]  @relation("Recipe4")

  facilityResources SfFacilityResource[]

  @@map("sf_resources")
}

model SfSystem {
  id      String     @id @default(cuid())
  name    String     @unique
  planets SfPlanet[]

  @@map("sf_systems")
}

model SfPlanet {
  id       String     @id @default(cuid())
  name     String
  systemId String
  system   SfSystem   @relation(fields: [systemId], references: [id])

  facilities         SfFacility[]
  facilityResources  SfFacilityResource[] @relation("FacilityResourcePlanet")
  subfacility1       SfFacilityResource[] @relation("Subfacility1")
  subfacility2       SfFacilityResource[] @relation("Subfacility2")
  subfacility3       SfFacilityResource[] @relation("Subfacility3")
  relays             SfFacilityResource[] @relation("Relay")

  @@unique([name, systemId])
  @@map("sf_planets")
}

model SfFacility {
  id           String               @id @default(cuid())
  name         String
  abbreviation String               @unique
  planetId     String
  planet       SfPlanet             @relation(fields: [planetId], references: [id])
  resources    SfFacilityResource[]

  @@map("sf_facilities")
}

model SfFacilityResource {
  id            String      @id @default(cuid())
  facilityId    String
  facility      SfFacility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      SfResource  @relation(fields: [resourceId], references: [id])
  planetId      String
  planet        SfPlanet    @relation("FacilityResourcePlanet", fields: [planetId], references: [id])
  subfacility1Id String?
  subfacility1  SfPlanet?   @relation("Subfacility1", fields: [subfacility1Id], references: [id])
  subfacility2Id String?
  subfacility2  SfPlanet?   @relation("Subfacility2", fields: [subfacility2Id], references: [id])
  subfacility3Id String?
  subfacility3  SfPlanet?   @relation("Subfacility3", fields: [subfacility3Id], references: [id])
  relayId       String?
  relay         SfPlanet?   @relation("Relay", fields: [relayId], references: [id])
  onsite        Boolean     @default(false)

  @@unique([facilityId, resourceId, planetId])
  @@map("sf_facility_resources")
}