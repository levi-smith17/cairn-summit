// iCloud Calendar connections

model ICloudCalendar {
  id          String   @id @default(cuid())
  appleId     String
  passwordEnc String
  calendarUrl String
  name        String
  color       String   @default("#6b7280")
  createdAt   DateTime @default(now())
  wayfarerId  String
  wayfarer    Wayfarer @relation(fields: [wayfarerId], references: [id], onDelete: Cascade)
  stops       Stop[]

  @@map("icloud_calendars")
}
