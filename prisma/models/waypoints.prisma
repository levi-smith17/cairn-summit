model Waypoint {
  id          String               @id @default(cuid())
  url         String
  title       String
  description String?
  favicon     String?
  notes       String?
  read        Boolean              @default(false)
  readLater   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  wayfarerId  String
  wayfarer    Wayfarer             @relation(fields: [wayfarerId], references: [id])
  markers     MarkersOnWaypoints[]
  trail       Trail?               @relation(fields: [trailId], references: [id])
  trailId     String?              @map("folderId")
  logs        Log[]
}

model MarkersOnWaypoints {
  waypoint   Waypoint @relation(fields: [waypointId], references: [id])
  waypointId String
  marker     Marker   @relation(fields: [markerId], references: [id])
  markerId   String   @map("tagId")

  @@id([waypointId, markerId])
  @@map("TagsOnWaypoints")
}
